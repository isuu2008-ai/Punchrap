{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PunchLab",
  "version": "0.1.0",
  "identifier": "ai.isuu2008.punchrap",
  "build": {
    "beforeDevCommand": "node ../server.mjs",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PunchLab",
        "width": 1180,
        "height": 760,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../desktop-host-manifest.json",
      "../desktop-wrapper-manifest.json",
      "../desktop-package-manifest.json",
      "../plugin-host-manifest.json"
    ]
  }
}
