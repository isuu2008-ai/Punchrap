{
  "appId": "ai.isuu2008.punchrap",
  "appName": "PunchLab",
  "packageVersion": 1,
  "preferredWrapper": {
    "framework": "Tauri",
    "fallback": "Electron",
    "reason": "Local-first desktop shell with native audio and plugin host bridges."
  },
  "entry": {
    "webEntry": "index.html",
    "devServer": "http://localhost:4173",
    "productionDir": ".",
    "tauriConfig": "src-tauri/tauri.conf.json"
  },
  "fileAssociations": [
    {
      "id": "project",
      "name": "PunchLab Project",
      "extension": ".punchlab.json",
      "mimeType": "application/vnd.punchlab.project+json",
      "role": "Editor"
    },
    {
      "id": "archive",
      "name": "PunchLab Archive",
      "extension": ".punchlab.zip",
      "mimeType": "application/vnd.punchlab.archive+zip",
      "role": "Editor"
    }
  ],
  "tauriCapabilities": [
    {
      "id": "main",
      "path": "src-tauri/capabilities/main.json",
      "windows": [
        "main"
      ],
      "permissions": [
        "core:default",
        "dialog:default",
        "fs:default"
      ]
    }
  ],
  "requiredArtifacts": [
    "index.html",
    "desktop-package-manifest.json",
    "desktop-host-manifest.json",
    "desktop-wrapper-manifest.json",
    "plugin-host-manifest.json",
    "src-tauri/tauri.conf.json",
    "src-tauri/capabilities/main.json",
    "src/engine-contract.js",
    "src/native-bridge.js",
    "src/native-adapter.js",
    "src/project.js",
    "src/desktop.js"
  ],
  "packagingStages": [
    {
      "id": "wrapper-scaffold",
      "label": "Create Tauri/Electron shell",
      "status": "scaffolded"
    },
    {
      "id": "file-association",
      "label": "Register .punchlab.json and .punchlab.zip",
      "status": "scaffolded"
    },
    {
      "id": "native-audio-bridge",
      "label": "Attach native low-latency audio bridge",
      "status": "planned"
    },
    {
      "id": "plugin-host-bridge",
      "label": "Attach VST3/AU plugin host bridge",
      "status": "planned"
    }
  ],
  "nativeMigrationGate": {
    "startDesktopPackagingWhen": [
      "recording and recent-take audition are stable",
      "project save/load and zip archive metadata are stable",
      "batch vocal chain rendering is stable",
      "desktop readiness checks pass"
    ],
    "noRewriteBoundary": [
      "src/engine-contract.js",
      "src/chain-params.js",
      "src/project.js",
      "src/native-bridge.js",
      "src/native-adapter.js",
      "src/desktop.js"
    ]
  },
  "verificationCommands": [
    "node scripts/check.mjs",
    "node scripts/check-desktop-contract.mjs"
  ]
}
