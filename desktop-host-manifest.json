{
  "appId": "ai.isuu2008.punchrap",
  "appName": "PunchLab",
  "bridgeVersion": 1,
  "bridgeGlobal": "__PUNCHLAB_NATIVE__",
  "projectFormat": ".punchlab.json",
  "bundleFormat": ".punchlab.zip",
  "requiredNativeMethods": [
    "getCapabilities",
    "getDevices",
    "renderMix",
    "renderVocal",
    "startInputMonitor",
    "stopInputMonitor"
  ],
  "optionalNativeMethods": [
    "getLatencyStats",
    "setOutputDevice",
    "setBufferSize",
    "openProjectFile",
    "saveProjectFile",
    "exportCompressedAudio",
    "scanPluginHosts"
  ],
  "requiredEngineCapabilities": [
    "offlineMixRender",
    "vocalRender",
    "pitchAnalysis",
    "wavExport",
    "loudnessAnalysis",
    "truePeakLimiter"
  ],
  "optionalEngineCapabilities": [
    "compressedAudioExport",
    "realtimeNativeMonitoring",
    "pluginHost"
  ],
  "nativeAudioEngine": {
    "sampleRates": [
      44100,
      48000
    ],
    "bufferSizes": [
      64,
      128,
      256,
      512,
      1024
    ],
    "preferredBufferSize": 128,
    "maxRoundTripLatencyMs": 10,
    "requiresExclusiveAudioThread": true
  },
  "contracts": {
    "chainParams": "src/chain-params.js",
    "engine": "src/engine-contract.js",
    "bridge": "src/native-bridge.js",
    "nativeFixture": "src/native-fixture.js",
    "nativeAdapter": "src/native-adapter.js",
    "project": "src/project.js",
    "desktop": "src/desktop.js"
  }
}
